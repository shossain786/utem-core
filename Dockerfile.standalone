# Lightweight image for running a pre-built JAR.
# Build the JAR first: mvn clean package -DskipTests
# Then run: docker build -f Dockerfile.standalone -t utem-core .
FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
RUN mkdir -p /app/data
COPY target/utem-core-0.1.0.jar app.jar
ENV SPRING_DATASOURCE_URL=jdbc:sqlite:/app/data/utem.db
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
